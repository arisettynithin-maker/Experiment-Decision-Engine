{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FollowUpQuestions",
  "type": "object",
  "required": ["needs_follow_up", "questions", "rationale"],
  "properties": {
    "needs_follow_up": { "type": "boolean" },
    "questions": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "object",
        "required": ["question_id", "question_text"],
        "properties": {
          "question_id": { "type": "string" },
          "question_text": { "type": "string" }
        }
      }
    },
    "rationale": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
