{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StructuredExperimentBrief",
  "type": "object",
  "required": [
    "experiment_name",
    "experiment_slug",
    "brief_status",
    "business_problem",
    "hypothesis",
    "target_segment",
    "primary_metric",
    "secondary_metrics",
    "guardrail_metrics",
    "experiment_type",
    "recommended_test_design",
    "randomization_unit",
    "expected_effect",
    "success_criteria",
    "instrumentation_requirements",
    "assumptions",
    "risks",
    "implementation_notes",
    "missing_information"
  ],
  "properties": {
    "experiment_name": { "type": "string" },
    "experiment_slug": { "type": "string" },
    "brief_status": {
      "type": "string",
      "enum": ["complete", "needs_clarification"]
    },
    "business_problem": { "type": "string" },
    "hypothesis": { "type": "string" },
    "target_segment": { "type": "string" },
    "primary_metric": { "type": "string" },
    "secondary_metrics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "guardrail_metrics": {
      "type": "array",
      "items": { "type": "string" }
    },
    "experiment_type": { "type": "string" },
    "recommended_test_design": { "type": "string" },
    "randomization_unit": { "type": "string" },
    "expected_effect": { "type": "string" },
    "success_criteria": { "type": "string" },
    "instrumentation_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "implementation_notes": { "type": "string" },
    "missing_information": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
